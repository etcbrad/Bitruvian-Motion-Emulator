{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bitruvianmotionemulator",
  "compatibility_date": "2026-04-07",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/public",
    "not_found_handling": "single-page-application"
  }
}
